# ─────────────────────────────────────────────────────
# 环境变量模板
# 复制为 .env 并填入你的真实值：
#   cp .env.example .env
# ─────────────────────────────────────────────────────

# Application
APP_NAME=AI-Interview
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=<在此填入随机字符串>

# Database
DATABASE_URL=mysql+aiomysql://root:<密码>@localhost:3306/ai_interview
DATABASE_URL_SYNC=mysql+pymysql://root:<密码>@localhost:3306/ai_interview

# Redis
REDIS_URL=redis://localhost:6379/0

# Chroma
CHROMA_PERSIST_DIR=./chroma_data

# DeepSeek LLM
DEEPSEEK_API_KEY=<在此填入你的DeepSeek API Key>
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_CONNECT_TIMEOUT_SECONDS=10
DEEPSEEK_READ_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_RETRIES=2
LLM_RETRY_BACKOFF_BASE_SECONDS=0.5
LLM_RETRY_BACKOFF_MAX_SECONDS=5
INTERVIEW_AGENT_TIMEOUT_SECONDS=90
REACT_AGENT_RECURSION_LIMIT=20
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
LLM_CIRCUIT_BREAKER_RECOVERY_SECONDS=60

# Ollama Embedding
OLLAMA_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=bge-m3

# Ollama Reranker
OLLAMA_NATIVE_URL=http://localhost:11434
RERANK_MODEL=bge-reranker-v2-m3

# JWT
JWT_SECRET_KEY=<在此填入随机JWT密钥>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP Email
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=<你的QQ邮箱>
SMTP_PASSWORD=<QQ邮箱SMTP授权码>
SMTP_FROM=<你的QQ邮箱>
SMTP_USE_TLS=true
